# ===== REQUIRED =====

# Your domain (for nginx SSL)
DOMAIN=yourdomain.com

# Frontend URL (used by backend for CORS + Stripe redirects)
FRONTEND_URL=https://yourdomain.com

# Strong random string — at least 64 chars
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string

# Database
POSTGRES_PASSWORD=change_me_strong_db_password

# Redis
REDIS_PASSWORD=change_me_strong_redis_password

# Stripe (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ===== OPTIONAL =====

# OpenAI (for AI Fix Advisor + AI Executive Summary features)
# Get from platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# SMTP (for email verification, password reset, monitoring alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=SecurityScan <noreply@yourdomain.com>

# Cookie security (set to true in production)
COOKIE_SECURE=true
